    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lenis": "^1.3.25",
    "lucide-react": "^0.344.0",
    "mongoose": "^9.7.4",
